# ═══════════════════════════════════════════════════════════════════
# MyCow — Variables de entorno (Vite)
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas `.env` al repositorio. CERO hardcoding en el código.
# ═══════════════════════════════════════════════════════════════════

# URL del proyecto Supabase (Dashboard > Settings > API > Project URL)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Anon/public key de Supabase (Dashboard > Settings > API > anon public)
# Es segura para exponer en el cliente SIEMPRE que RLS esté habilitado.
VITE_SUPABASE_ANON_KEY=eyJ...TU_ANON_KEY

# Nombre de la aplicación (se muestra en la UI / manifest de la PWA)
VITE_APP_NAME=MyCow

# Eslogan corto de la aplicación
VITE_APP_TAGLINE=Gestión ganadera offline-first

# ═══════════════════════════════════════════════════════════════════
# Motor de sincronización offline (src/sync). CERO hardcoding: si se
# omite alguna, el motor usa el default documentado a la derecha.
# ═══════════════════════════════════════════════════════════════════

# Nombre de la base local IndexedDB (Dexie). Default: mycow_sync
VITE_SYNC_DB_NAME=mycow_sync

# Cadencia del auto-sync del scheduler, en ms. Default: 30000 (30 s)
VITE_SYNC_INTERVAL_MS=30000

# Reintentos máximos de una op del outbox antes de quedar como
# dead-letter (ya no se reintenta sola). Default: 5
VITE_SYNC_MAX_RETRIES=5

# Base del backoff exponencial entre reintentos, en ms
# (delay del intento n = base * 2^n). Default: 1000 (1 s)
VITE_SYNC_BACKOFF_BASE_MS=1000
